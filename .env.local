# Backend API base URL for proxy
NEXT_PUBLIC_API_BASE_URL=https://oauth.nexaorion.cn

# App metadata
NEXT_PUBLIC_APP_NAME=LoliAuth
NEXT_PUBLIC_APP_DESCRIPTION=OAuth 2.0 Identity Platform

# Cookie key for auth token
NEXT_PUBLIC_TOKEN_COOKIE_KEY=loliauth_token

# hCaptcha site key (get yours at https://dashboard.hcaptcha.com)
# Use 10000000-ffff-ffff-ffff-000000000001 for local testing (always-pass test key)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
